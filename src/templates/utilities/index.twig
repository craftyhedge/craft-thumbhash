{% set utilityAction = 'thumbhash/utilities/queue-generate' %}
{% set clearAction = 'thumbhash/utilities/clear-all' %}
{% set statusAction = 'thumbhash/utilities/job-status' %}
{% set rowsAction = 'thumbhash/utilities/grid-rows' %}
{% set initialRows = initialRows ?? [] %}
{% set initialHashRows = initialHashRows ?? [] %}
{% set generateDataUrl = generateDataUrl ?? true %}

<form id="thumbhash-generator" class="utility" method="post" accept-charset="UTF-8">
    {{ csrfInput() }}

    <h2 class="first">{{ 'ThumbHash Generation'|t('thumbhash') }}</h2>

    {% if not generateDataUrl %}
        <p class="warning" style="margin-top: var(--s);">
            {{ 'PNG placeholder generation disabled.'|t('thumbhash') }}
        </p>
    {% endif %}

    <div class="buttons" style="display:flex; align-items:center; gap:var(--s); flex-wrap:wrap;">
        <button type="submit" class="btn submit">{{ 'Generate'|t('thumbhash') }}</button>
        <button type="button" class="btn" id="thumbhash-clear-all">{{ 'Clear All'|t('thumbhash') }}</button>
        <div class="utility-status" style="flex:1 1 16rem; min-width:0; display:flex; align-items:center;"></div>
    </div>
</form>

<div style="margin-top: var(--xl);">
    {% set pngCount = initialRows|length %}
    {% set hashCount = initialHashRows|length %}
    {% set displayCount = pngCount > 0 ? pngCount : hashCount %}

    <p class="light" style="margin-top: 0; margin-bottom: var(--s);">
        {{ 'ThumbHashes:'|t('thumbhash') }}
        <span id="thumbhash-grid-count">{{ displayCount }}</span>
    </p>

    <div id="thumbhash-png-grid" style="display:grid; grid-template-columns: repeat(auto-fill, minmax(28px, 1fr)); gap: 2px;">
        {% for row in initialRows %}
            <div class="thumbhash-png-item" data-asset-id="{{ row.assetId }}" title="Asset #{{ row.assetId }}" style="display:block; width: 100%; aspect-ratio: 1 / 1;">
                <img src="{{ row.dataUrl }}" alt="" loading="lazy" style="display:block; width:100%; height:100%; object-fit:cover; border-radius:0px;" />
            </div>
        {% endfor %}
    </div>

    <div id="thumbhash-hash-list" class="{{ initialRows|length == 0 and initialHashRows|length ? '' : 'hidden' }}" style="margin-top: var(--s);">
        <p class="light" style="margin-top: 0; margin-bottom: var(--xs);">{{ 'Stored hashes:'|t('thumbhash') }}</p>
        <ul id="thumbhash-hash-items" style="margin: 0; padding-left: 1.2rem; max-height: 18rem; overflow:auto;">
            {% for row in initialHashRows %}
                {% if row.hash %}
                    <li class="thumbhash-hash-item" data-asset-id="{{ row.assetId }}" style="margin-bottom: 2px;"><code>#{{ row.assetId }}: {{ row.hash }}</code></li>
                {% endif %}
            {% endfor %}
        </ul>
    </div>

    <p id="thumbhash-assets-empty" class="light{{ initialRows|length or initialHashRows|length ? ' hidden' : '' }}" style="margin-top: var(--s);">{{ 'Hit generate to start.'|t('thumbhash') }}</p>
</div>

{% css %}
#thumbhash-png-grid {
    position: relative;
    overflow: hidden;
    isolation: isolate;
}

#thumbhash-png-grid.thumbhash-grid-loading .thumbhash-png-item {
    opacity: 1;
    transition: opacity 140ms linear;
}

#thumbhash-png-grid.thumbhash-grid-loading::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 2;
    background: linear-gradient(
        108deg,
        rgba(255, 255, 255, 0) 28%,
        rgba(255, 255, 255, 0.34) 50%,
        rgba(255, 255, 255, 0) 72%
    );
    transform: translateX(-130%);
    animation: thumbhash-grid-sweep 1.5s linear infinite;
}

#thumbhash-png-grid.thumbhash-grid-loading .thumbhash-png-item img,
#thumbhash-png-grid.thumbhash-grid-loading .thumbhash-png-item span {
    filter: saturate(0.96);
}

@keyframes thumbhash-grid-sweep {
    from {
        transform: translateX(-130%);
    }

    to {
        transform: translateX(130%);
    }
}

@media (prefers-reduced-motion: reduce) {
    #thumbhash-png-grid.thumbhash-grid-loading::after {
        animation: none;
        transform: none;
        opacity: 0;
    }

    #thumbhash-png-grid.thumbhash-grid-loading .thumbhash-png-item {
        opacity: 0.78;
    }
}
{% endcss %}

{% js %}
(() => {
    const $form = $('#thumbhash-generator');
    const $submitButton = $form.find('button.submit:last');
    const $clearButton = $('#thumbhash-clear-all');
    const $status = $form.find('.utility-status');

    const queueAction = '{{ utilityAction|e('js') }}';
    const clearAction = '{{ clearAction|e('js') }}';
    const statusAction = '{{ statusAction|e('js') }}';
    const rowsAction = '{{ rowsAction|e('js') }}';
    const $grid = $('#thumbhash-png-grid');
    const $hashList = $('#thumbhash-hash-list');
    const $gridCount = $('#thumbhash-grid-count');
    const $empty = $('#thumbhash-assets-empty');
    const prefersPngIndicator = {{ generateDataUrl ? 'true' : 'false' }};

    let runTotal = 0;
    let pollTimer = null;
    let pollRequestActive = false;
    let gridRequestActive = false;
    let frozenAssetOrder = $grid.find('[data-asset-id]').map((_, el) => String($(el).data('asset-id'))).get();
    let activeIndicatorMode = $hashList.hasClass('hidden') ? 'png' : 'hash';

    const indicatorState = {
        png: {
            initialized: false,
            cursorUpdatedAt: null,
            cursorAssetId: 0,
        },
        hash: {
            initialized: false,
            cursorUpdatedAt: null,
            cursorAssetId: 0,
        },
    };

    const pngNodeMap = new Map();
    const hashNodeMap = new Map();

    if (!prefersPngIndicator) {
        activeIndicatorMode = 'hash';
    }

    const resetIndicatorState = () => {
        indicatorState.png.initialized = false;
        indicatorState.png.cursorUpdatedAt = null;
        indicatorState.png.cursorAssetId = 0;
        indicatorState.hash.initialized = false;
        indicatorState.hash.cursorUpdatedAt = null;
        indicatorState.hash.cursorAssetId = 0;
    };

    const escapeHtml = (value) => {
        return String(value)
            .replaceAll('&', '&amp;')
            .replaceAll('<', '&lt;')
            .replaceAll('>', '&gt;')
            .replaceAll('"', '&quot;')
            .replaceAll("'", '&#39;');
    };

    const setGridLoading = (isLoading) => {
        if (isLoading) {
            $grid.addClass('thumbhash-grid-loading');
            $grid.attr('aria-busy', 'true');
            return;
        }

        $grid.removeClass('thumbhash-grid-loading');
        $grid.removeAttr('aria-busy');
    };

    const ensureHashListSkeleton = () => {
        let $hashItems = $hashList.find('#thumbhash-hash-items');

        if ($hashItems.length > 0) {
            return $hashItems;
        }

        $hashList.html(`
            <p class="light" style="margin-top: 0; margin-bottom: var(--xs);">${Craft.t('thumbhash', 'Stored hashes:')}</p>
            <ul id="thumbhash-hash-items" style="margin: 0; padding-left: 1.2rem; max-height: 18rem; overflow:auto;"></ul>
        `);

        $hashItems = $hashList.find('#thumbhash-hash-items');
        return $hashItems;
    };

    const rebuildNodeMapsFromDom = () => {
        pngNodeMap.clear();
        hashNodeMap.clear();

        $grid.find('.thumbhash-png-item[data-asset-id]').each((_, el) => {
            const $el = $(el);
            pngNodeMap.set(String($el.data('asset-id')), $el);
        });

        $hashList.find('.thumbhash-hash-item[data-asset-id]').each((_, el) => {
            const $el = $(el);
            hashNodeMap.set(String($el.data('asset-id')), $el);
        });
    };

    rebuildNodeMapsFromDom();

    const renderSnapshot = (rows, hashRows) => {
        const pngRows = Array.isArray(rows) ? rows : [];
        const fallbackHashRows = Array.isArray(hashRows) ? hashRows : [];

        if (pngRows.length === 0 && fallbackHashRows.length === 0) {
            $grid.html('');
            $hashList.addClass('hidden').html('');
            $gridCount.text('0');
            $empty.removeClass('hidden');
            frozenAssetOrder = [];
            activeIndicatorMode = prefersPngIndicator ? 'png' : 'hash';
            rebuildNodeMapsFromDom();
            return {total: 0};
        }

        if (pngRows.length === 0) {
            const hashHtml = fallbackHashRows
                .filter((row) => row && row.hash)
                .map((row) => {
                    const assetId = escapeHtml(String(row.assetId ?? ''));
                    const hash = escapeHtml(String(row.hash ?? ''));
                    return `<li class="thumbhash-hash-item" data-asset-id="${assetId}" style="margin-bottom: 2px;"><code>#${assetId}: ${hash}</code></li>`;
                })
                .join('');

            $grid.html('');
            frozenAssetOrder = [];
            $hashList.html(`
                <p class="light" style="margin-top: 0; margin-bottom: var(--xs);">${Craft.t('thumbhash', 'Stored hashes:')}</p>
                <ul id="thumbhash-hash-items" style="margin: 0; padding-left: 1.2rem; max-height: 18rem; overflow:auto;">${hashHtml}</ul>
            `).removeClass('hidden');
            $gridCount.text(String(fallbackHashRows.length));
            $empty.addClass('hidden');
            activeIndicatorMode = 'hash';
            rebuildNodeMapsFromDom();
            return {total: fallbackHashRows.length};
        }

        if (!Array.isArray(frozenAssetOrder) || frozenAssetOrder.length === 0) {
            frozenAssetOrder = pngRows.map((row) => String(row.assetId ?? ''));
        }

        const rowsById = new Map();
        pngRows.forEach((row) => {
            rowsById.set(String(row.assetId ?? ''), row);
        });

        const orderedRows = [];
        frozenAssetOrder.forEach((assetId) => {
            if (rowsById.has(assetId)) {
                orderedRows.push(rowsById.get(assetId));
                rowsById.delete(assetId);
            }
        });

        pngRows.forEach((row) => {
            const assetId = String(row.assetId ?? '');
            if (rowsById.has(assetId)) {
                orderedRows.push(row);
                frozenAssetOrder.push(assetId);
                rowsById.delete(assetId);
            }
        });

        const html = orderedRows.map((row) => {
            const assetId = escapeHtml(String(row.assetId ?? ''));
            const dataUrl = row.dataUrl ? escapeHtml(row.dataUrl) : '';

            const tileInner = dataUrl
                ? `<img src="${dataUrl}" alt="" loading="lazy" style="display:block; width:100%; height:100%; object-fit:cover; border-radius:2px;" />`
                : '<span aria-hidden="true" style="display:block; width:100%; height:100%; border-radius:4px; border:1px dashed var(--hairlineColor); background: color-mix(in srgb, var(--gray-100) 70%, transparent);"></span>';

            return `<div class="thumbhash-png-item" data-asset-id="${assetId}" title="Asset #${assetId}" style="display:block; width: 100%; aspect-ratio: 1 / 1;">${tileInner}</div>`;
        }).join('');

        $grid.html(html);
        $hashList.addClass('hidden').html('');
        $gridCount.text(String(orderedRows.length));
        $empty.addClass('hidden');
        activeIndicatorMode = 'png';
        rebuildNodeMapsFromDom();

        return {
            total: orderedRows.length,
        };
    };

    const applyPngDelta = (rows) => {
        const pngRows = Array.isArray(rows) ? rows : [];

        if (pngRows.length === 0) {
            return {total: pngNodeMap.size};
        }

        activeIndicatorMode = 'png';

        pngRows.forEach((row) => {
            const assetId = String(row?.assetId ?? '');
            const encodedAssetId = escapeHtml(assetId);
            const dataUrl = row?.dataUrl ? escapeHtml(String(row.dataUrl)) : '';

            if (!assetId || !dataUrl) {
                return;
            }

            const tileInner = `<img src="${dataUrl}" alt="" loading="lazy" style="display:block; width:100%; height:100%; object-fit:cover; border-radius:4px;" />`;
            const $existing = pngNodeMap.get(assetId);

            if ($existing) {
                const $img = $existing.find('img');
                if ($img.length > 0) {
                    if ($img.attr('src') !== dataUrl) {
                        $img.attr('src', dataUrl);
                    }
                } else {
                    $existing.html(tileInner);
                }

                return;
            }

            const $node = $(`<div class="thumbhash-png-item" data-asset-id="${encodedAssetId}" title="Asset #${encodedAssetId}" style="display:block; width: 100%; aspect-ratio: 1 / 1;">${tileInner}</div>`);
            $grid.append($node);
            pngNodeMap.set(assetId, $node);

            if (!frozenAssetOrder.includes(assetId)) {
                frozenAssetOrder.push(assetId);
            }
        });

        if (!$hashList.hasClass('hidden')) {
            $hashList.addClass('hidden').html('');
            hashNodeMap.clear();
            indicatorState.hash.initialized = false;
            indicatorState.hash.cursorUpdatedAt = null;
            indicatorState.hash.cursorAssetId = 0;
        }

        $gridCount.text(String(pngNodeMap.size));
        $empty.addClass('hidden');

        return {total: pngNodeMap.size};
    };

    const applyHashDelta = (rows) => {
        const hashRows = Array.isArray(rows) ? rows : [];

        if (hashRows.length === 0) {
            return {total: hashNodeMap.size};
        }

        activeIndicatorMode = 'hash';

        if ($grid.children().length > 0) {
            $grid.html('');
            pngNodeMap.clear();
            frozenAssetOrder = [];
            indicatorState.png.initialized = false;
            indicatorState.png.cursorUpdatedAt = null;
            indicatorState.png.cursorAssetId = 0;
        }

        const $hashItems = ensureHashListSkeleton();

        hashRows.forEach((row) => {
            const assetId = String(row?.assetId ?? '');
            const encodedAssetId = escapeHtml(assetId);
            const hash = row?.hash ? escapeHtml(String(row.hash)) : '';

            if (!assetId || !hash) {
                return;
            }

            const $existing = hashNodeMap.get(assetId);
            const innerHtml = `<code>#${encodedAssetId}: ${hash}</code>`;

            if ($existing) {
                $existing.html(innerHtml);
                return;
            }

            const $node = $(`<li class="thumbhash-hash-item" data-asset-id="${encodedAssetId}" style="margin-bottom: 2px;">${innerHtml}</li>`);
            $hashItems.append($node);
            hashNodeMap.set(assetId, $node);
        });

        $hashList.removeClass('hidden');
        $gridCount.text(String(hashNodeMap.size));
        $empty.addClass('hidden');

        return {total: hashNodeMap.size};
    };

    const normalizeIndicatorMode = (value, fallback = 'png') => {
        const mode = String(value || '').toLowerCase();

        if (mode === 'hash' || mode === 'png') {
            return mode;
        }

        return fallback;
    };

    const updateIndicatorCursor = (mode, payload) => {
        const state = indicatorState[mode];
        const cursorUpdatedAt = String(payload?.cursorUpdatedAt || '').trim();
        const cursorAssetId = Number(payload?.cursorAssetId || 0);

        if (cursorUpdatedAt !== '') {
            state.cursorUpdatedAt = cursorUpdatedAt;
            state.cursorAssetId = Number.isFinite(cursorAssetId) && cursorAssetId > 0
                ? Math.floor(cursorAssetId)
                : 0;
        } else if (!state.cursorUpdatedAt) {
            state.cursorUpdatedAt = '1970-01-01 00:00:00';
            state.cursorAssetId = 0;
        }

        state.initialized = true;
    };

    const requestGridRows = async (mode, { forceFull = false } = {}) => {
        const normalizedMode = normalizeIndicatorMode(mode, prefersPngIndicator ? 'png' : 'hash');
        const state = indicatorState[normalizedMode];
        const data = {
            _: Date.now(),
            mode: normalizedMode,
        };

        if (!forceFull && state.initialized && state.cursorUpdatedAt) {
            data.sinceUpdatedAt = state.cursorUpdatedAt;
            data.sinceAssetId = state.cursorAssetId;
        }

        return Craft.sendActionRequest('GET', rowsAction, {
            data,
        });
    };

    const applyRowsResponse = (mode, payload) => {
        const normalizedMode = normalizeIndicatorMode(mode, prefersPngIndicator ? 'png' : 'hash');
        const isDelta = Boolean(payload?.delta);

        if (normalizedMode === 'hash') {
            if (isDelta) {
                return applyHashDelta(payload?.hashRows || []);
            }

            return renderSnapshot([], payload?.hashRows || []);
        }

        if (isDelta) {
            return applyPngDelta(payload?.rows || []);
        }

        return renderSnapshot(payload?.rows || [], []);
    };

    const loadGridRows = async ({ forceFull = false } = {}) => {
        if (gridRequestActive) {
            return;
        }

        try {
            gridRequestActive = true;

            let requestedMode = normalizeIndicatorMode(activeIndicatorMode, prefersPngIndicator ? 'png' : 'hash');
            let response = await requestGridRows(requestedMode, { forceFull });
            let responseMode = normalizeIndicatorMode(response.data?.mode, requestedMode);
            let snapshot = applyRowsResponse(responseMode, response.data || {});
            updateIndicatorCursor(responseMode, response.data || {});
            activeIndicatorMode = responseMode;

            if (responseMode === 'png' && snapshot?.total === 0) {
                requestedMode = 'hash';
                response = await requestGridRows(requestedMode, { forceFull });
                responseMode = normalizeIndicatorMode(response.data?.mode, requestedMode);
                snapshot = applyRowsResponse(responseMode, response.data || {});
                updateIndicatorCursor(responseMode, response.data || {});
                activeIndicatorMode = responseMode;

                if (prefersPngIndicator && responseMode === 'hash' && (snapshot?.total || 0) === 0) {
                    activeIndicatorMode = 'png';
                }
            }

            return snapshot;
        } catch (error) {
            // Ignore transient grid refresh errors while polling.
            return null;
        } finally {
            gridRequestActive = false;
        }
    };

    const setButtonEnabled = (enabled) => {
        if (enabled) {
            $submitButton.removeClass('disabled');
            $submitButton.prop('disabled', false);
            $clearButton.removeClass('disabled');
            $clearButton.prop('disabled', false);
            return;
        }

        $submitButton.addClass('disabled');
        $submitButton.prop('disabled', true);
        $clearButton.addClass('disabled');
        $clearButton.prop('disabled', true);
    };

    const setFailedStatus = (message) => {
        const trimmedMessage = String(message || '').trim();

        if (trimmedMessage) {
            $status.text(Craft.t('thumbhash', 'Processing failed: {message}', {
                message: trimmedMessage,
            }));
            return;
        }

        $status.text(Craft.t('thumbhash', 'Processing failed. Some images may remain eligible for a future run.'));
    };

    const setCompletedWithFailuresStatus = (message) => {
        const trimmedMessage = String(message || '').trim();

        if (trimmedMessage) {
            $status.text(trimmedMessage);
            return;
        }

        $status.text(Craft.t('thumbhash', 'Processing completed with failures. Some images remain eligible for a future run. Check the ThumbHash logs for details.'));
    };

    const stopPolling = () => {
        if (!pollTimer) {
            return;
        }

        clearInterval(pollTimer);
        pollTimer = null;
    };

    const startPolling = () => {
        stopPolling();
        setGridLoading(true);

        pollTimer = setInterval(async () => {
            if (pollRequestActive) {
                return;
            }

            try {
                pollRequestActive = true;

                const response = await Craft.sendActionRequest('GET', statusAction, {
                    data: { _: Date.now() },
                });
                const run = response.data?.run || {};
                const hasRun = Boolean(run.hasRun);
                const runState = String(run.state || (hasRun ? 'running' : 'idle'));
                const runError = String(run.error || '');

                await loadGridRows();

                if (runState === 'failed') {
                    stopPolling();
                    setGridLoading(false);
                    setButtonEnabled(true);
                    setFailedStatus(runError);
                    return;
                }

                if (runState === 'completed_with_failures') {
                    stopPolling();
                    setGridLoading(false);
                    setButtonEnabled(true);
                    await loadGridRows();
                    setCompletedWithFailuresStatus(runError);
                    return;
                }

                const runComplete = runState === 'completed';
                if (runComplete) {
                    await loadGridRows({ forceFull: true });
                    stopPolling();
                    setGridLoading(false);
                    setButtonEnabled(true);
                    $status.text(Craft.t('thumbhash', 'Processing complete.'));
                    return;
                }

                const runProcessed = Number(run.processed || 0);
                const runTotalCount = Number(run.total || 0);
                if (runTotalCount > 0) {
                    const pct = Math.round((runProcessed / runTotalCount) * 100);
                    $gridCount.text(pct + '% (' + runProcessed + ' of ' + runTotalCount + ')');
                }
            } catch (error) {
                stopPolling();
                setGridLoading(false);
                setButtonEnabled(true);
                $status.text(Craft.t('thumbhash', 'Could not refresh progress.'));
            } finally {
                pollRequestActive = false;
            }
        }, 1000);
    };

    $form.on('submit', async (ev) => {
        ev.preventDefault();

        if ($submitButton.hasClass('disabled')) {
            return false;
        }

        setButtonEnabled(false);
        setGridLoading(true);
        $status.text(Craft.t('thumbhash', 'Queueing jobs...'));

        try {
            const response = await Craft.sendActionRequest('POST', queueAction);
            const isExistingRun = Boolean(response.data?.existingRun);

            runTotal = Number(response.data?.queued || 0);

            if (isExistingRun) {
                $status.text(Craft.t('thumbhash', 'Resuming processing...'));
                await loadGridRows();
                startPolling();
                return false;
            }

            if (runTotal === 0) {
                $status.text(Craft.t('thumbhash', 'No eligible images found.'));
                setGridLoading(false);
                setButtonEnabled(true);
                return false;
            }

            $status.text(Craft.t('thumbhash', 'Processing images...'));
            await loadGridRows();

            if (runTotal > 0) {
                $gridCount.text('0% (0 of ' + runTotal + ')');
            }

            startPolling();
        } catch (error) {
            setGridLoading(false);
            setButtonEnabled(true);
            $status.text(Craft.t('thumbhash', 'Could not queue jobs.'));
        }

        return false;
    });

    $clearButton.on('click', async () => {
        if ($clearButton.hasClass('disabled')) {
            return false;
        }

        const shouldClear = window.confirm(Craft.t('thumbhash', 'Clear all stored thumbhash records?'));
        if (!shouldClear) {
            return false;
        }

        setButtonEnabled(false);
        setGridLoading(false);
        $status.text(Craft.t('thumbhash', 'Clearing thumbhash records...'));

        try {
            const response = await Craft.sendActionRequest('POST', clearAction);
            const deleted = Number(response.data?.deleted || 0);
            $status.text(Craft.t('thumbhash', 'Cleared {count} records.', { count: deleted }));
            frozenAssetOrder = [];
            resetIndicatorState();
            activeIndicatorMode = prefersPngIndicator ? 'png' : 'hash';
            await loadGridRows();
        } catch (error) {
            $status.text(Craft.t('thumbhash', 'Could not clear thumbhash records.'));
        } finally {
            stopPolling();
            setGridLoading(false);
            setButtonEnabled(true);
        }

        return false;
    });

    const resumeFromServer = async () => {
        try {
            const response = await Craft.sendActionRequest('GET', statusAction, {
                data: { _: Date.now() },
            });
            const run = response.data?.run || {};
            const hasRun = Boolean(run.hasRun);
            const runState = String(run.state || (hasRun ? 'running' : 'idle'));
            const runError = String(run.error || '');

            if (runState === 'failed') {
                setGridLoading(false);
                setFailedStatus(runError);
                setButtonEnabled(true);
                return;
            }

            if (runState === 'completed_with_failures') {
                setGridLoading(false);
                await loadGridRows();
                setCompletedWithFailuresStatus(runError);
                setButtonEnabled(true);
                return;
            }

            if (!hasRun) {
                setGridLoading(false);
                return;
            }

            runTotal = Number(run.total || 0);

            if (runTotal <= 0) {
                setGridLoading(false);
                return;
            }

            $status.text(Craft.t('thumbhash', 'Resuming processing...'));
            setButtonEnabled(false);
            await loadGridRows();

            const resumeProcessed = Number(run.processed || 0);
            if (runTotal > 0) {
                const pct = Math.round((resumeProcessed / runTotal) * 100);
                $gridCount.text(pct + '% (' + resumeProcessed + ' of ' + runTotal + ')');
            }

            startPolling();
        } catch (error) {
            // Ignore resume errors; user can start a new run manually.
        }
    };

    resumeFromServer();

    window.addEventListener('beforeunload', stopPolling);
    window.addEventListener('pagehide', stopPolling);
})();
{% endjs %}
